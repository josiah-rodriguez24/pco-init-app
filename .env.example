# ===========================================
# PCO Init App — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.

# --- Required ---

# PostgreSQL connection string (used by Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/pco_app?schema=public"

# Planning Center API credentials (Personal Access Token)
# Generate at: https://api.planningcenteronline.com/oauth/applications
PLANNING_CENTER_CLIENT_ID="your_planning_center_client_id"
PLANNING_CENTER_SECRET="pco_pat_your_personal_access_token"

# Public base URL of this app (used for webhooks, OAuth callbacks)
APP_BASE_URL="http://localhost:3000"

# Node environment
NODE_ENV="development"

# --- Optional (not required for v1) ---

# Redis connection (for caching layer — future)
# REDIS_URL="redis://localhost:6379"

# Planning Center webhook secret (for HMAC verification — future)
# PLANNING_CENTER_WEBHOOK_SECRET="your-webhook-secret"
